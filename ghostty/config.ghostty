theme = Neobones Dark
custom-shader = ~/Library/Application Support/com.mitchellh.ghostty/shaders/space.glsl
font-family = "JetBrainsMono"
font-size = 18
background-blur-radius = 20
mouse-hide-while-typing = true
window-decoration = true
window-padding-x = 8
macos-option-as-alt = true
initial-command = /opt/homebrew/bin/tmux new-session -A -s default

